<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.factmesh.admin.infrastructure.database.mapper.UserMapper">

    <!-- 根据用户名查询用户 -->
    <select id="findByUsername" resultType="com.ly.factmesh.admin.infrastructure.database.entity.UserEntity">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

</mapper>
