<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ly.factmesh.admin.infrastructure.database.mapper.DictMapper">

    <!-- 根据字典类型和字典代码查询字典 -->
    <select id="findByDictTypeAndDictCode" resultType="com.ly.factmesh.admin.infrastructure.database.entity.DictEntity">
        SELECT * FROM sys_dict WHERE dict_type = #{dictType} AND dict_code = #{dictCode}
    </select>

    <!-- 根据字典类型查询字典列表 -->
    <select id="findByDictType" resultType="com.ly.factmesh.admin.infrastructure.database.entity.DictEntity">
        SELECT * FROM sys_dict WHERE dict_type = #{dictType} ORDER BY sort_order ASC
    </select>

</mapper>
